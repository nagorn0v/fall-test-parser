{
  "manifest_version": 3,
  "name": "My First Extension",
  "version": "1.0.0",
  "description": "Показывает теги провалившихся тестов",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Показать провалившиеся тесты",
    "default_icon": {
      "16": "error.png"
    }
  },
  "icons": {
    "16": "error.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://jenkins-py.bars.group/*"
  ]
}